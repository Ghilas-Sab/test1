---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  imageSrc: ImageMetadata;
  alt: string;
  caption: string;
  dialogId: string;
}

const { imageSrc, alt, caption, dialogId } = Astro.props;
---

<div class="group">
  <!-- Thumbnail cliquable -->
  <button
    onclick={`document.getElementById('${dialogId}').showModal()`}
    class="w-full block cursor-pointer focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 rounded-lg"
    aria-label={`Agrandir la photo : ${caption}`}
  >
    <Image
      src={imageSrc}
      alt={alt}
      width={400}
      height={300}
      class="w-full h-52 object-cover rounded-lg transition-transform duration-300 group-hover:scale-105 group-hover:shadow-lg"
      loading="lazy"
    />
    <p class="mt-2 text-sm text-gray-600 text-center font-medium">{caption}</p>
  </button>
</div>

<!-- Dialog lightbox -->
<dialog
  id={dialogId}
  aria-label={`Photo agrandie : ${caption}`}
  class="p-0 rounded-xl shadow-2xl max-w-4xl w-[90vw] backdrop:bg-black/75 open:animate-none"
  onclick="if(event.target === this) this.close()"
>
  <div class="relative bg-white rounded-xl overflow-hidden">
    <button
      onclick={`document.getElementById('${dialogId}').close()`}
      class="absolute top-3 right-3 z-10 bg-white/90 rounded-full w-9 h-9 flex items-center justify-center text-gray-600 hover:bg-white hover:text-gray-900 transition-colors shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500"
      aria-label="Fermer la photo"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <Image
      src={imageSrc}
      alt={alt}
      width={1200}
      height={800}
      class="w-full h-auto"
      loading="lazy"
    />
    <p class="px-6 py-4 text-center text-gray-700 font-medium text-lg">{caption}</p>
  </div>
</dialog>
